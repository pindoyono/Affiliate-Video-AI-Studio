generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String        @id @default(uuid())
  email      String        @unique
  password   String
  name       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  videos     Video[]
  presenters Presenter[]
  products   Product[]
  knowledge  KnowledgeBase[]
}

model Product {
  id             String          @id @default(uuid())
  userId         String
  title          String
  description    String?
  imageUrl       String?
  images         String[]
  price          Float?
  discount       Float?
  rating         Float?
  soldCount      Int?
  affiliateUrl   String?
  sourceUrl      String
  sourceType     SourceType
  trendScore     Float?
  trendData      Json?
  searchVolume   Int?
  growthVelocity Float?
  seasonality    Float?
  creatorCount   Int?
  status         ProductStatus   @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id])
  videos         Video[]
  trendAnalyses  TrendAnalysis[]
  affiliateData  AffiliateData?
}

enum SourceType {
  SHOPEE
  TIKTOK
  MANUAL
}

enum ProductStatus {
  PENDING
  ACTIVE
  FAILED
}

model TrendAnalysis {
  id                    String   @id @default(uuid())
  productId             String
  salesGrowth           Float    @default(0)
  engagementGrowth      Float    @default(0)
  affiliateAvailable    Boolean  @default(false)
  competitionLevel      Float    @default(0)
  estimatedConversion   Float    @default(0)
  trendScore            Float    @default(0)
  analyzedAt            DateTime @default(now())
  product               Product  @relation(fields: [productId], references: [id])
}

model Video {
  id           String      @id @default(uuid())
  userId       String
  productId    String
  presenterId  String?
  title        String
  mode         VideoMode   @default(FACELESS)
  status       VideoStatus @default(DRAFT)
  outputUrl    String?
  thumbnailUrl String?
  duration     Float?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id])
  product      Product     @relation(fields: [productId], references: [id])
  presenter    Presenter?  @relation(fields: [presenterId], references: [id])
  scenes       Scene[]
  analytics    VideoAnalytics[]
}

enum VideoMode {
  FACELESS
  AI_PRESENTER
  HYBRID
}

enum VideoStatus {
  DRAFT
  RENDERING
  COMPLETED
  FAILED
}

model Scene {
  id            String      @id @default(uuid())
  videoId       String
  order         Int
  prompt        String?
  imagePrompt   String?
  imageUrl      String?
  audioUrl      String?
  narrationText String?
  narrationUrl  String?
  duration      Float       @default(5)
  status        SceneStatus @default(PENDING)
  video         Video       @relation(fields: [videoId], references: [id])
}

enum SceneStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Presenter {
  id             String   @id @default(uuid())
  userId         String
  name           String
  description    String?
  appearance     Json?
  sampleImageUrl String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
  videos         Video[]
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  category  String?
  embedding Float[]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AffiliateData {
  id                  String   @id @default(uuid())
  productId           String   @unique
  platform            String
  commissionRate      Float    @default(0)
  estimatedCommission Float    @default(0)
  affiliateAvailable  Boolean  @default(false)
  shortLink           String?
  shortCode           String?  @unique
  clickCount          Int      @default(0)
  conversionCount     Int      @default(0)
  updatedAt           DateTime @updatedAt
  product             Product  @relation(fields: [productId], references: [id])
}

model VideoAnalytics {
  id          String   @id @default(uuid())
  videoId     String
  views       Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  watchTime   Float    @default(0)
  retention   Float    @default(0)
  conversion  Float    @default(0)
  revenue     Float    @default(0)
  roi         Float    @default(0)
  recordedAt  DateTime @default(now())
  video       Video    @relation(fields: [videoId], references: [id])
}

model JobQueue {
  id        String    @id @default(uuid())
  type      String
  status    JobStatus @default(PENDING)
  payload   Json?
  result    Json?
  error     String?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

